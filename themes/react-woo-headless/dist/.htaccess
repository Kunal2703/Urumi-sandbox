# Long-cache hashed Vite output.
# Files in /assets/ have content-based hashes (e.g. index-DqCYw0yD.js)
# so they're safe to cache forever — a content change produces a new
# filename, which busts the cache automatically.
#
# Public/ files (favicons, OG image, hero video) are NOT hashed; they
# get a shorter cache window so updates roll out within a day.
#
# Apache/LiteSpeed honor this directly. On nginx, replicate via:
#   location ~ ^/wp-content/themes/react-woo-headless/dist/assets/ {
#     expires 1y; add_header Cache-Control "public, immutable";
#   }

<IfModule mod_headers.c>
    # Hashed Vite assets — immutable, 1 year
    <FilesMatch "\.(js|css|woff2?|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Public assets copied into dist/ during build (hero video, OG image,
    # favicons, lottie JSON, illustrations) — 30 day cache, allow revalidation
    <FilesMatch "\.(webp|png|jpe?g|svg|mp4|webm|mov|json|ico)$">
        Header set Cache-Control "public, max-age=2592000, must-revalidate"
    </FilesMatch>
</IfModule>

# Brotli/Gzip — let the server pick precompressed siblings (.br/.gz)
# generated by vite-plugin-compression at build time.
<IfModule mod_brotli.c>
    AddType application/javascript .br
    AddType text/css .br
    AddOutputFilterByType BROTLI_COMPRESS application/javascript text/css text/html
</IfModule>
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE application/javascript text/css text/html application/json image/svg+xml
</IfModule>

# Force correct MIME types
<IfModule mod_mime.c>
    AddType application/javascript .js
    AddType text/css .css
    AddType image/webp .webp
    AddType image/svg+xml .svg
    AddType application/json .json
    AddType video/mp4 .mp4
    AddType video/webm .webm
</IfModule>
